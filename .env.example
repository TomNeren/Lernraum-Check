# LernSpiel Environment Configuration
# Copy this to .env and fill in your values

# Admin password for the dashboard
ADMIN_PASSWORD=lernspiel2026

# Anthropic Claude API Key (for AI feedback workflow)
CLAUDE_API_KEY=sk-ant-...

# Claude model for AI feedback (default: claude-haiku-4-5-20251001)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Max tokens for AI responses (default: 500)
CLAUDE_MAX_TOKENS=500

# Google API Key (for additional services)
GOOGLE_API_KEY=AIza...

# Server settings
PORT=8090
HOSTNAME=0.0.0.0

# CORS allowed origin (default: https://srl.infotore.cc)
# Set to * for local development
CORS_ORIGIN=https://srl.infotore.cc

# Max upload size in MB (increased for PDF uploads)
MAX_UPLOAD_MB=50
