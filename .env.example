# LernHub Environment Configuration
# Copy this to .env and fill in your values

# Admin password for the dashboard
ADMIN_PASSWORD=lernspiel2026

# ─── AI Model Configuration ───────────────────────────────────────
# Priority: Apple Foundation Model → Claude API → Gemini API → Local fallback

# Apple Foundation Model (free, on-device, macOS 15.4+ with Apple Silicon)
# Set this to the local endpoint if running the FM bridge service
# APPLE_FM_ENDPOINT=http://localhost:8091/generate

# ─── Anthropic Claude API ─────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# Claude model options (pick one):
#   claude-haiku-4-5-20251001   — fast, cheap, good for feedback/exercises
#   claude-sonnet-4-6           — balanced, better quality
#   claude-opus-4-6             — best quality, slower, most expensive
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Max tokens for AI responses (default: 500)
CLAUDE_MAX_TOKENS=500

# ─── Google Gemini API ────────────────────────────────────────────
# Alternative to Claude — set GEMINI_API_KEY to use Gemini models
GOOGLE_API_KEY=AIza...
# GEMINI_API_KEY=AIza...

# Gemini model options (pick one):
#   gemini-2.0-flash            — fast, free tier available
#   gemini-2.0-flash-lite       — fastest, most cost-effective
#   gemini-2.5-pro-preview      — best quality, thinking model
#   gemini-2.5-flash-preview    — good balance of speed and quality
# GEMINI_MODEL=gemini-2.0-flash

# ─── Task-specific model overrides ────────────────────────────────
# Override the default model per task type (optional)
# Uses CLAUDE_MODEL or GEMINI_MODEL as fallback if not set
# AI_MODEL_FEEDBACK=claude-haiku-4-5-20251001
# AI_MODEL_EXERCISES=gemini-2.0-flash
# AI_MODEL_GENERAL=claude-haiku-4-5-20251001

# ─── Server settings ──────────────────────────────────────────────
PORT=8090
HOSTNAME=0.0.0.0

# Max upload size in MB (increased for PDF uploads)
MAX_UPLOAD_MB=50
